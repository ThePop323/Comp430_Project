def testing2():
    db = connecttoDB()


    ##Gets all the dims for compliance checks
    market_fact = getData('''DEV4.TEST_MARKET_FACT''',db)
    date_dim = getData("DEV.DATE_DIM",db) # day = 0 month = 1 year = 3 datekey = 5
    time_dim = getData("DEV.TIME_DIM",db)
    asset_dim = getData("DEV.ASSET_DIM",db)


    assetname = "META"
    ticker = yfinance.Ticker(assetname)
    assetkey = getAssetKey(asset_dim,assetname)
    data = ticker.history(period="1d", interval="15m")
    latest = data.iloc[-2]

    #datetest =
    datekey, timekey = getDateKey(date_dim,time_dim,latest.name)
    print("date key :"+str(datekey)+" | Time key : "+str(timekey) +" | Asset Key : " + str(assetkey))
    print(latest)

    # checks to see if values are non zero and non negative
    latest.Open = checkValidInt(latest.Open)
    latest.High = checkValidInt(latest.High)
    latest.Low = checkValidInt(latest.Low)
    latest.Close = checkValidInt(latest.Close)
    latest.Volume = checkValidInt(latest.Volume)

    print("Datetime: "+ str(latest.name))
    print("Open: "+str(latest.Open))
    print("High: "+str(latest.High))
    print("Low: "+str(latest.Low))
    print("Close: "+str(latest.Close))
    print("Volume: "+str(latest.Volume))

    # add check for if factdata[-1][0] has data inside if not will break
    params = {
        'MARKETFACTKEY': None,
        'DATEKEY': datekey,
        'ASSETKEY': assetkey,
        'SOURCEKEY': 1,
        'OPEN_PRICE': latest.Open,
        'VOLUME': latest.Volume,
        'TIME_KEY': timekey,
        'HIGH_PRICE': latest.High,
        'LOW_PRICE': latest.Low
    }
    print(params)
    if not checkDuplicate(market_fact,datekey,timekey,assetkey):
        pass
        #insertData(params,db)
    else:
        print("Refusing to input due to params already being inside fact table")
    print(getData('''DEV4.TEST_MARKET_FACT''',db))
